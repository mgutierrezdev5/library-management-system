{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run Library Project",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "\"C:\\vscode\\MinGW\\bin\\g++.exe\" src\\main.c src\\book.c src\\menu.c src\\file_manager.c -Iinclude -o library.exe && library.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}